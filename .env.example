# API
CUE_DATABASE_URL=postgresql+psycopg2://cue:cue@localhost:5432/cue_math
CUE_REDIS_URL=redis://localhost:6379/0
CUE_STORAGE_PATH=./storage
CUE_CORS_ORIGINS_RAW=http://localhost:5173
CUE_DEFAULT_DUE_LIMIT=30
CUE_OCR_LANGUAGE=eng
CUE_SECTION_MIN_CHARS=700
CUE_SECTION_MAX_CHARS=1800
CUE_HLR_ENABLED=true
CUE_HLR_SERVICE_URL=http://localhost:8010
CUE_HLR_TIMEOUT_SECONDS=2.0
CUE_HLR_MIN_REVIEWS_PER_CARD=5
CUE_HLR_DEFAULT_TARGET_RECALL=0.78

# Groq AI (get a free key at https://console.groq.com/keys)
CUE_GROQ_API_KEY=your-groq-api-key-here
CUE_GROQ_MODEL=llama-3.3-70b-versatile
CUE_GROQ_TEMPERATURE=0.7

# Web
VITE_API_URL=http://localhost:8000/api
